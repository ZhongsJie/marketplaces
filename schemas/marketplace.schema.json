{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Marketplace Registry",
  "type": "object",
  "required": ["name", "version", "plugins"],
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "description": { "type": "string" },
    "homepage": { "type": "string", "format": "uri" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "plugins": {
      "type": "array",
      "items": { "$ref": "#/definitions/PluginEntry" }
    }
  },
  "definitions": {
    "PluginEntry": {
      "type": "object",
      "required": ["id", "name", "version", "description", "author", "category", "path"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "name": { "type": "string" },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "description": { "type": "string" },
        "author": { "type": "string" },
        "category": {
          "type": "string",
          "enum": ["productivity", "coding", "design", "devops", "testing", "ai", "utility"]
        },
        "tags": { "type": "array", "items": { "type": "string" } },
        "path": { "type": "string" },
        "homepage": { "type": "string", "format": "uri" },
        "repository": { "type": "string", "format": "uri" },
        "license": { "type": "string" },
        "publishedAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "downloads": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
